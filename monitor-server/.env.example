# ── 应用 ──
APP_DEBUG=true

# ── 数据库 ──
DATABASE_URL=sqlite:///./monitor.db

# ── 人脸图片存储 ──
FACE_IMAGE_DIR=./face_images
MAX_AVATAR_SIZE=10485760

# ── 录制回放 ──
CACHE_DURATION_SECONDS=30
RECORD_STOP_SILENCE_SECONDS=60

# ── 服务 ──
HOST=0.0.0.0
PORT=8000

# ── RTMP / SRS ──
RTMP_HOST=127.0.0.1
RTMP_PORT=1935
RTMP_DEBUG=false
SRS_HOST=127.0.0.1
SRS_RTMP_PORT=1935
SRS_HTTP_PORT=8080
# SRS_PUBLIC_HOST=10.126.59.25
# SRS_PUBLIC_RTMP_PORT=1935
# SRS_PUBLIC_HTTP_PORT=8082

# ── Stream readiness ──
STREAM_READY_TIMEOUT=30.0
STREAM_PROBE_TIMEOUT=8.0
STREAM_READY_INTERVAL=1.0

# ── AI 推理管线 ──
FPS_TARGET=15
YOLO_CONFIDENCE=0.5
YOLO_MODEL_PATH=src/third-party/yolo/yolo11n.pt
STREAM_RECONNECT_MAX_RETRIES=10
FACE_MATCH_TOLERANCE=0.6
FACE_SKIP_FRAMES=5
YAMNET_THRESHOLD=0.5
DWELL_TIME_DEFAULT=10
DENSITY_DEFAULT=0.6
LEAVE_FRAMES_DEFAULT=5
ALERT_CHECK_INTERVAL=5
ALERT_EVENT_TTL=5
ALERT_COOLDOWN=30
BYTETRACK_TRACK_THRESH=0.5
BYTETRACK_MATCH_THRESH=0.8

# ── Node WebSocket ──
WSS_NODE_PORT=8000
WSS_NODE_DEBUG=false

# ── 本地 View 流调试 ──
DEBUG_WEB_STREAM=false

# ── JWT 认证 ──
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8
